# Environment configuration for the shell-dex MVP

# Optional: live swap quote API base URL
NEXT_PUBLIC_SHELL_DEX_ROUTER_URL=

# Optional: router contract used when a quote includes executable calldata
NEXT_PUBLIC_SHELL_DEX_ROUTER_ADDRESS=

# Optional: liquidity manager/spender used by the simulated liquidity flow
NEXT_PUBLIC_SHELL_DEX_LIQUIDITY_MANAGER_ADDRESS=

# Optional: bridge contract placeholders used by the simulated bridge flow
NEXT_PUBLIC_STARGATE_ROUTER_ADDRESS=
NEXT_PUBLIC_STARGATE_EXECUTOR_ADDRESS=
